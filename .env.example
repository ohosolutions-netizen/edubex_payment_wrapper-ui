ZOHO_ACCOUNTS_BASE_URL=https://accounts.zoho.in
ZOHO_API_BASE_URL=https://www.zohoapis.in
ZOHO_CLIENT_ID=your_client_id
ZOHO_CLIENT_SECRET=your_client_secret
ZOHO_REFRESH_TOKEN=your_refresh_token

# Use the module and field API names from Zoho CRM Setup -> Developer Hub -> APIs & SDKs.
ZOHO_PAYMENT_MODULE_API_NAME=Payment_Schedule
ZOHO_STATUS_FIELD_API_NAME=Payment_Status
ZOHO_FORM_URL_FIELD_API_NAME=Form_Link

# Optional comma-separated values treated as completed.
# Any other payment status opens the form.
COMPLETED_STATUS_VALUES=Payment Completed,Completed
